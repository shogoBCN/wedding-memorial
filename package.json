{
  "name": "wedding-memorial",
  "private": true,
  "type": "module",
  "scripts": {
    "optimize:assets": "node scripts/optimize-assets.mjs",
    "build": "node scripts/build-site.mjs",
    "serve": "npx --yes serve web",
    "serve:dist": "npx --yes serve dist",
